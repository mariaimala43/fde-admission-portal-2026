  <tr><td><span class="code-inline">app/Http/Controllers/Hoi/MeritListController.php</span></td><td>Controller</td><td>HOI uploads files (max 10 MB each, multiple allowed), lists and deletes their own school's files</td></tr>
  <tr><td><span class="code-inline">app/Http/Controllers/Fde/MeritListController.php</span></td><td>Controller</td><td>FDE views and manages merit lists for all institutions</td></tr>
  <tr><td><span class="code-inline">resources/views/hoi/merit_lists/index.blade.php</span></td><td>View</td><td>HOI upload form + file listing</td></tr>
  <tr><td><span class="code-inline">resources/views/fde/merit_lists/index.blade.php</span></td><td>View</td><td>FDE management view — grouped by school with search</td></tr>
  <tr><td><span class="code-inline">resources/views/portal/merit_lists.blade.php</span></td><td>View</td><td>Public portal page listing all merit lists by school</td></tr>
  <tr><td><span class="code-inline">database/migrations/0037_create_institution_merit_lists_table.php</span></td><td>Migration</td><td>Table: institution_id, file_path, original_name, title, file_size, created_at</td></tr>
  <tr><td><span class="code-inline">database/migrations/0038_add_file_size_to_institution_merit_lists_table.php</span></td><td>Migration</td><td>Added file_size column (separate migration)</td></tr>
</table>

