# =============================================================================
#  FDE Admission Portal 2026 — Nginx Server Block Template
#
#  1. Copy this file:
#       sudo cp nginx.conf.example /etc/nginx/sites-available/fde-portal
#
#  2. Edit the two lines marked with  ← CHANGE THIS
#
#  3. Enable & reload:
#       sudo ln -s /etc/nginx/sites-available/fde-portal /etc/nginx/sites-enabled/
#       sudo nginx -t
#       sudo systemctl reload nginx
#
#  4. (Optional) Add HTTPS with Certbot:
#       sudo certbot --nginx -d your-domain.com
# =============================================================================

server {
    listen 80;
    listen [::]:80;

    server_name your-domain.com;                          # ← CHANGE THIS

    root /var/www/fde-admission-portal-2026/public;       # ← CHANGE THIS (full path to /public)
    index index.php;

    charset utf-8;
    client_max_body_size 64M;

    # ── Laravel front-controller ──────────────────────────────────────────────
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # ── PHP-FPM ───────────────────────────────────────────────────────────────
    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/run/php/php8.2-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_index index.php;
        fastcgi_read_timeout 120;
    }

    # ── Static asset caching ─────────────────────────────────────────────────
    location ~* \.(js|css|svg|png|jpg|jpeg|ico|woff|woff2|ttf|eot|gif|webp|mp4)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # ── Training video — allow large file streaming ──────────────────────────
    location /videos/ {
        mp4;
        mp4_buffer_size     1m;
        mp4_max_buffer_size 5m;
        add_header Accept-Ranges bytes;
    }

    # ── Security: block hidden files ─────────────────────────────────────────
    location ~ /\.(?!well-known).* {
        deny all;
    }

    # ── Logging ──────────────────────────────────────────────────────────────
    access_log /var/log/nginx/fde-portal-access.log;
    error_log  /var/log/nginx/fde-portal-error.log;
}
